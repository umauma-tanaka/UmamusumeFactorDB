# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
pytest-cache-files-*/

# 仮想環境
.venv/

# 機密・資格情報
config/apps_script_webhook.json
config/service_account.json
config/*.secret.json
.env

# モデルバイナリ（サイズが大きいため除外）
# 例外: ★分類器は軽量かつ推論に必須なのでリポジトリに含める
models/**/*.onnx
!models/modules/star_classifier/
!models/modules/star_classifier/labels.json
!models/modules/star_classifier/prediction.onnx
!models/modules/star_classifier/prediction.onnx.data

# デバッグ出力
debug_crops/
debug_crops*/
debug_*_trace/
debug_*/
debug_*.png
*.log

# CNN 学習の中間生成物（生データ・チェックポイント・生成モデル）
# 個別に除外（datasets/ 全体除外だと negation が効かないため）
datasets/stars/
datasets/finetune/
artifacts/
models/easyocr/
models/easyocr_user_network/
outputs/
paddleocr_cache/
rapidocr_models/
# テンプレマッチ用の正解 crop（datasets/red_blue_templates, star_templates,
# green_name_templates）はパッケージの一部として commit する

# ローカルの作業用バックアップ・一時ファイル
backups/
*.bak

# OCR 精度評価の生成物（ラベラー UI / バッチ推論結果 / 途中保存 / ダウンロード CSV）
tests/fixtures/colored_factors/recognition_results*.json
tests/fixtures/colored_factors/labeler.html
tests/fixtures/colored_factors/labels_*.csv
tests/fixtures/colored_factors/labels_progress_*.json

# IDE
.vscode/
.idea/

# Office の編集中ロックファイル
~$*
